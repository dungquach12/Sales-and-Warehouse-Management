{{#section 'head'}}
<script src="/assets/scripts/order.js" defer></script>
{{/section}}

<!-- Modern POS Page -->
<main class="pos-container">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h5 class="fw-bold mb-1">
        <i class="bi bi-cart-plus text-primary me-2"></i>
        Bán hàng
      </h5>
      <p class="text-muted small mb-0">Tạo đơn hàng mới nhanh chóng</p>
    </div>
    <div class="text-muted small">
      <i class="bi bi-clock me-1"></i>
      <span id="currentTime"></span>
    </div>
  </div>

  <div class="row g-4">

    <!-- Left Panel - Products -->
    <div class="col-12 col-lg-8">
      
      <!-- Search & Filter Bar -->
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
          <div class="d-flex flex-wrap gap-2">
            <div class="flex-grow-1">
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                  <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" class="form-control border-start-0" id="searchProduct" 
                       placeholder="Tìm kiếm sản phẩm...">
              </div>
            </div>
            <select id="categoryFilter" class="form-select w-auto" style="min-width: 140px;">
              <option value="all">📂 Tất cả danh mục</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Products Grid -->
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="row g-2" id="productGrid">
            <div class="col-12 text-center py-5">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel - Cart -->
    <div class="col-12 col-lg-4">
      <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
        
        <!-- Cart Header -->
        <div class="card-header bg-white border-0 pt-3 pb-0">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-bag-check me-2 text-primary"></i>
            Đơn hàng hiện tại
          </h6>
        </div>

        <div class="card-body pt-3">
          
          <!-- Customer Info -->
          <div class="mb-3">
            <label class="form-label small fw-semibold text-muted">
              <i class="bi bi-person me-1"></i>Khách hàng
            </label>
            <input type="text" class="form-control form-control-sm" id="customerName" 
                   placeholder="Nhập tên khách (không bắt buộc)">
          </div>

          <div class="row g-2 mb-3">
            <!-- Order Method -->
            <div class="col-6">
              <label class="form-label small fw-semibold text-muted">
                <i class="bi bi-shop me-1"></i>Hình thức
              </label>
              <select id="orderMethod" class="form-select form-select-sm">
                <option value="Tại chỗ">🪑 Tại chỗ</option>
                <option value="Mang đi">🛍 Mang đi</option>
                <option value="Giao hàng">🛵 Giao hàng</option>
              </select>
            </div>
            
            <!-- Payment Method -->
            <div class="col-6">
              <label class="form-label small fw-semibold text-muted">
                <i class="bi bi-credit-card me-1"></i>Thanh toán
              </label>
              <select id="paymentMethod" class="form-select form-select-sm">
                <option value="Tiền mặt">💵 Tiền mặt</option>
                <option value="Chuyển khoản">📱 Chuyển khoản</option>
              </select>
            </div>
          </div>

          <!-- Cart Items -->
          <div class="border-top pt-3 mt-2">
            <div id="cartItems">
              <div class="text-center text-muted py-4">
                <i class="bi bi-cart fs-1 d-block mb-2 opacity-50"></i>
                <span class="small">Chưa có sản phẩm nào</span>
              </div>
            </div>
          </div>

          <!-- Cart Summary -->
          <div class="border-top pt-3 mt-2">
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted small">Tạm tính</span>
              <span class="fw-semibold" id="subtotal">0đ</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
              <span class="text-muted small">Thuế (0%)</span>
              <span class="fw-semibold">0đ</span>
            </div>
            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
              <span class="fw-bold fs-6">Tổng cộng</span>
              <span class="fw-bold fs-4 text-primary" id="totalAmount">0đ</span>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="d-flex gap-2 mt-4">
            <button class="btn btn-outline-danger flex-grow-1" id="clearCartBtn" disabled>
              <i class="bi bi-trash3 me-1"></i>Xóa
            </button>
            <button class="btn btn-dark flex-grow-1 py-2 fw-bold" id="submitOrderBtn" disabled>
              <i class="bi bi-check-circle me-1"></i>
              Xác nhận đơn
            </button>
          </div>

        </div>
      </div>
    </div>
  </div>
</main>

<!-- Toast Notification -->
<div class="toast-container position-fixed bottom-0 start-50 translate-middle-x mb-3">
  <div id="toast" class="toast align-items-center text-bg-dark border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body fw-bold" id="toastMsg"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>

</script>