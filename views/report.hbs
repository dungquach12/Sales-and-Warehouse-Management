{{#section 'head'}}
<script src="/assets/scripts/report.js" defer></script>
{{/section}}

<!-- Detail order modal -->
<div class="modal fade" id="detailOrderModal" tabindex="-1" aria-labelledby="detailOrderModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="detailOrderModalLabel">
          <i class="bi bi-receipt me-2"></i>
          Chi tiết đơn hàng
          <span class="badge bg-secondary ms-2" id="orderDate"></span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <!-- Customer Info Row -->
        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <div class="border rounded-3 p-3 bg-light">
              <div class="small text-muted mb-1">Khách hàng</div>
              <div class="fw-semibold" id="orderCustomer">—</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded-3 p-3 bg-light">
              <div class="small text-muted mb-1">Thanh toán</div>
              <div class="fw-semibold" id="orderPayment">—</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded-3 p-3 bg-light">
              <div class="small text-muted mb-1">Hình thức</div>
              <div class="fw-semibold" id="orderMethod">—</div>
            </div>
          </div>
        </div>

        <!-- Items Table -->
        <div class="table-responsive">
          <table class="table table-sm table-hover">
            <thead class="table-light">
              <tr>
                <th>Sản phẩm</th>
                <th class="text-center" style="width: 80px">SL</th>
                <th class="text-end" style="width: 120px">Đơn giá</th>
                <th class="text-end" style="width: 120px" id="profitHeader" style="display: none;">Lợi nhuận</th>
                <th class="text-end" style="width: 130px">Thành tiền</th>
              </tr>
            </thead>
            <tbody id="orderItems">
              <tr>
                <td colspan="5" class="text-center text-muted">Chưa có dữ liệu
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Total Row -->
        <div class="row mt-3">
          <div class="col-12">
            <div class="bg-light rounded-3 p-3">
              <div class="row align-items-center">
                <div class="col-md-6">
                  <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Tạm tính:</span>
                    <span id="orderSubtotal">0đ</span>
                  </div>
                  <div class="d-flex justify-content-between" id="profitRow" style="display: none;">
                    <span class="text-muted">Lợi nhuận:</span>
                    <span class="text-success fw-semibold" id="orderProfit">0đ</span>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="border-top pt-2 mt-2 mt-md-0">
                    <div class="d-flex justify-content-between align-items-center">
                      <span class="text-muted">Tổng cộng:</span>
                      <span class="fs-5 fw-bold text-primary" id="orderTotal">0đ</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
      </div>
    </div>
  </div>
</div>

<!-- Report Page -->
<main>
  <!-- Period selector -->
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h6 class="fw-bold mb-0">Tổng quan</h6>
    <div class="btn-group">
      <button class="btn btn-sm btn-outline-secondary period-btn active" data-period="today">Hôm nay</button>
      <button class="btn btn-sm btn-outline-secondary period-btn" data-period="week">7 ngày</button>
      <button class="btn btn-sm btn-outline-secondary period-btn" data-period="month">30 ngày</button>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="row g-3 mb-3">
    <div class="col-12 col-lg-3 col-md-6 col-sm-12">
      <div class="card stat-card bg-success bg-opacity-10 p-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small">Doanh thu</div>
            <div class="fw-bold fs-5 mt-1" id="statRevenue">0đ</div>
            <div class="small mt-1" id="statRevenueChange"></div>
          </div>
          <div class="stat-icon bg-success bg-opacity-25">💰</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-lg-3 col-md-6 col-sm-12">
      <div class="card stat-card bg-primary bg-opacity-10 p-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small">Đơn hàng</div>
            <div class="fw-bold fs-5 mt-1" id="statOrders">0</div>
            <div class="small mt-1" id="statOrdersChange"></div>
          </div>
          <div class="stat-icon bg-primary bg-opacity-25">🧾</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-lg-3 col-md-6 col-sm-12">
      <div class="card stat-card bg-warning bg-opacity-10 p-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small">Trung bình/đơn</div>
            <div class="fw-bold fs-5 mt-1" id="statAvg">0đ</div>
            <div class="small mt-1" id="statAvgChange"></div>
          </div>
          <div class="stat-icon bg-warning bg-opacity-25">📊</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-lg-3 col-md-6 col-sm-12">
      <div class="card stat-card bg-danger bg-opacity-10 p-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small">Lợi nhuận</div>
            <div class="fw-bold fs-5 mt-1" id="statProfit">0đ</div>
            <div class="small mt-1" id="statProfitChange"></div>
          </div>
          <div class="stat-icon bg-danger bg-opacity-25">📈</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts row -->
  <div class="row g-3 mb-3">

    <!-- Revenue chart -->
    <div class="col-12 col-md-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0">Doanh thu theo giờ</h6>
            <span class="text-muted small" id="chartSubtitle">Hôm nay</span>
          </div>
          <div class="chart-bar-wrap" id="revenueChart"></div>
        </div>
      </div>
    </div>

    <!-- Payment split -->
    <div class="col-12 col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="fw-bold mb-3">Hình thức thanh toán</h6>
          <div class="d-flex flex-column gap-3" id="paymentSplit">
            <div>
              <div class="d-flex justify-content-between small mb-1">
                <span>💵 Tiền mặt</span>
                <span class="fw-bold" id="cashAmount">0đ</span>
              </div>
              <div class="progress" style="height:8px;">
                <div class="progress-bar bg-success" id="cashBar" style="width:0%"></div>
              </div>
            </div>
            <div>
              <div class="d-flex justify-content-between small mb-1">
                <span>📱 Chuyển khoản</span>
                <span class="fw-bold" id="transferAmount">0đ</span>
              </div>
              <div class="progress" style="height:8px;">
                <div class="progress-bar bg-primary" id="transferBar" style="width:0%"></div>
              </div>
            </div>
          </div>

          <hr />

          <!-- Order method split -->
          <h6 class="fw-bold mb-3">Hình thức đặt hàng</h6>
          <div class="d-flex flex-column gap-2" id="methodSplit">
            <div class="d-flex justify-content-between align-items-center">
              <span class="small">🪑 Tại chỗ</span>
              <span class="badge bg-secondary bg-opacity-10 text-secondary fw-normal" id="dineInCount">0 đơn</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
              <span class="small">🛍 Mang đi</span>
              <span class="badge bg-secondary bg-opacity-10 text-secondary fw-normal" id="takeawayCount">0 đơn</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
              <span class="small">🛵 Giao hàng</span>
              <span class="badge bg-secondary bg-opacity-10 text-secondary fw-normal" id="deliveryCount">0 đơn</span>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom row -->
  <div class="row g-3">

    <!-- Top selling -->
    <div class="col-12 col-md-5">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="fw-bold mb-3">🏆 Bán chạy nhất</h6>
          <div class="d-flex flex-column gap-3" id="topProducts"></div>
        </div>
      </div>
    </div>

    <!-- Recent orders -->
    <div class="col-12 col-md-7">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="fw-bold mb-3">🧾 Đơn hàng gần đây</h6>
          <div class="table-responsive">
            <table class="table table-borderless table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="small">Thời gian</th>
                  <th class="small">Khách</th>
                  <th class="small d-none d-md-block">Món</th>
                  <th class="small">Tổng</th>
                  <th class="small">TT</th>
                </tr>
              </thead>
              <tbody id="recentOrders"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<script>

</script>