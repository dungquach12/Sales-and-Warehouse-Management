{{#section 'head'}}
<script src="/assets/scripts/product.js" defer></script>
{{/section}}


<!-- Product Management Page -->
<!-- Add / Edit Product Modal -->
<div class="modal fade" id="productModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <input type="text" hidden id="productId" />
        <h5 class="modal-title fw-bold" id="modalTitle">Thêm mặt hàng</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex flex-column gap-3">
          <div>
            <label class="form-label fw-semibold">Tên mặt hàng <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="inputName" list="nameList" placeholder="Nhập tên mặt hàng..."
              autocomplete="on" />
            <div id="nameFeedback" class="form-text"></div>
            <datalist id="nameList">

            </datalist>
          </div>
          <div>
            <label class="form-label fw-semibold">Danh mục</label>
            <select name="category" id="categorySelect" class="form-control">
              <option value="" disabled selected>-- Chọn danh mục --</option>
            </select>
          </div>
          <div class="row g-2">
            <div class="col-6">
              <label class="form-label fw-semibold">Giá bán <span class="text-danger">*</span></label>
              <div class="input-group">
                <input type="number" class="form-control" id="inputPrice" placeholder="0" min="0" />
                <span class="input-group-text">đ</span>
              </div>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Chi phí</label>
              <div class="input-group">
                <input type="number" class="form-control" id="inputCost" placeholder="0" min="0" />
                <span class="input-group-text">đ</span>
              </div>
            </div>
          </div>
          <div>
            <label class="form-label fw-semibold">Emoji</label>
            <input type="text" class="form-control" id="inputImage" placeholder="☕" maxlength="2" />
            <div class="form-text">Chọn một emoji đại diện cho mặt hàng</div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-success fw-bold" id="saveBtn" onclick="submitProduct()">
          <i class="bi bi-check-lg me-1"></i>Lưu
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Add Category Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Thêm danh mục</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-semibold">Tên danh mục <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="newCategoryName" placeholder="Nhập tên danh mục..." />
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-success fw-bold" id="saveCategoryBtn">
          <i class="bi bi-check-lg me-1"></i>Lưu
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Archive / Unarchive Confirm Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-body text-center py-4">
        <i id="archiveModalIcon" class="bi bi-archive text-warning fs-1 d-block mb-3"></i>

        <h6 id="archiveModalTitle" class="fw-bold">Lưu vào kho mặt hàng?</h6>

        <input type="hidden" id="archiveProductId" />
        <p class="text-muted small mb-0" id="archiveProductNameDisplay"></p>
      </div>
      <div class="modal-footer border-0 justify-content-center">
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
          <button type="button" class="btn btn-warning fw-bold" id="confirmArchiveBtn" onclick="handleArchiveToggle()">
            Xác nhận
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Page -->
<main class="page-wrapper">

  <!-- Sticky top section -->
  <div class="sticky-section d-flex flex-column gap-3 pb-0">

    <!-- Top bar -->
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
      <div class="d-flex gap-2">
        <div class="p-0 bg-white rounded border border-dark-subtle d-flex align-items-center" id="statusFilter">
          <button id="activedProduct" class="btn rounded-end-0 fw-bold product-status-btn">
            <span>Còn bán</span>
          </button>
          <button id="inactivedProduct" class="btn rounded-start-0 fw-bold product-status-btn-disabled">
            <span>Ngừng bán</span>
          </button>
        </div>
      </div>
      <div class="d-inline-flex gap-2">
        <div class="input-group" style="max-width:240px;">
          <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search text-muted"></i>
          </span>
          <input type="text" class="form-control border-start-0" id="searchInput" placeholder="Tìm kiếm..." />
        </div>
        <button class="btn btn-success fw-bold" id="addProductBtn" data-bs-toggle="modal" data-bs-target="#productModal"
          onclick="prepareAddProductModal()">
          <i class="bi bi-plus-circle-fill me-1"></i>
          <span>Thêm mặt hàng</span>
        </button>
        <button class="btn btn-success fw-bold" id="addCategoryBtn" data-bs-toggle="modal"
          data-bs-target="#categoryModal" onclick="prepareAddCategoryModal()">
          <i class="bi bi-plus-circle-fill me-1"></i>
          <span>Thêm danh mục</span>
        </button>
      </div>
    </div>

    <!-- Stats -->
    <div class="row g-2">
      <div class="col-6 col-md-3">
        <div class="card border-0 bg-success bg-opacity-10">
          <div class="card-body py-3 stat-card">
            <div class="text-muted small">Tổng mặt hàng</div>
            <div class="fw-bold fs-4" id="statTotal">0</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 bg-warning bg-opacity-10">
          <div class="card-body py-3 stat-card">
            <div class="text-muted small">Danh mục</div>
            <div class="fw-bold fs-4" id="statCategories">0</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 bg-info bg-opacity-10">
          <div class="card-body py-3 stat-card">
            <div class="text-muted small">Giá cao nhất</div>
            <div class="fw-bold fs-4" id="statMaxPrice">0đ</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 bg-danger bg-opacity-10">
          <div class="card-body py-3 stat-card">
            <div class="text-muted small">Giá thấp nhất</div>
            <div class="fw-bold fs-4" id="statMinPrice">0đ</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bulk bar -->
    <div class="card border-danger d-none" id="bulkBar">
      <div class="card-body py-2 d-flex justify-content-between align-items-center">
        <span class="text-danger fw-bold small"><span id="selectedCount">0</span> mặt hàng được chọn</span>
        <button class="btn btn-danger btn-sm fw-bold" id="bulkDeleteBtn">
          <i class="bi bi-trash3 me-1"></i>Xóa đã chọn
        </button>
      </div>
    </div>

    <!-- Static table header -->
    <div class="card mb-0 border-0">
      <div class="card-body p-0">
        <table class="table table-borderless align-middle mb-0">
          <thead class="table-secondary">
            <tr>
              <th class="ps-3 pb-3 col-check">
                <input type="checkbox" class="form-check-input fs-5" id="checkAll" onclick="showBulkArchive()" />
              </th>
              <th class="col-name">
                <span>Mặt hàng</span>
                <button class="btn ms-auto" id="nameSortBtn">
                  <i class="bi bi-filter"></i>
                </button>
              </th>
              <th class="col-cat">
                <span>Danh mục</span>
                <button class="btn ms-auto" id="categorySortBtn">
                  <i class="bi bi-filter"></i>
                </button>
              </th>
              <th class="col-price">
                <span></span>Giá bán</span>
                <button class="btn ms-auto" id="priceSortBtn">
                  <i class="bi bi-filter"></i>
                </button>
              </th>
              <th class="col-cost">
                <span>Chi phí</span>
                <button class="btn ms-auto" id="costSortBtn">
                  <i class="bi bi-filter"></i>
                </button>
              </th>
              <th class="col-profit">
                <span>Lợi nhuận</span>
                <button class="btn ms-auto" id="profitSortBtn">
                  <i class="bi bi-filter"></i>
                </button>
              </th>
              <th class="col-action"></th>
            </tr>

          </thead>
        </table>
      </div>
    </div>

  </div>

  <!-- Scrollable table body -->
  <div class="table-wrapper card rounded-top-0 border-0">
    <div class="card-body p-0">
      <table class="table table-borderless table-hover align-middle">
        <colgroup>
          <col class="col-check" />
          <col class="col-name" />
          <col class="col-cat" />
          <col class="col-price" />
          <col class="col-cost" />
          <col class="col-profit" />
          <col class="col-action" />
        </colgroup>
        <tbody id="productTable">
          <!-- Render products here -->
        </tbody>
      </table>
    </div>
  </div>
</main>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 start-50 translate-middle-x mb-3">
  <div id="toast" class="toast align-items-center text-bg-dark border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body fw-bold" id="toastMsg"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>

</script>