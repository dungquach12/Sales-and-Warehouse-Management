<!-- Side bar -->
<div class="d-none d-md-flex flex-column bg-white shadow-sm" id="sidebar">
{{> sidebarMenu}}
</div>

<!-- Offcanva -->
<div
  class="offcanvas offcanvas-start"
  tabindex="-1"
  id="offcanvasSidebar"
  aria-labelledby="offcanvasSidebarLabel"
>
  <div class="offcanvas-header">
    <button
      type="button"
      class="btn-close"
      data-bs-dismiss="offcanvas"
      aria-label="Close"
    ></button>
  </div>

  <div class="offcanvas-body p-0">
    <div>
      {{> sidebarMenu}}
    </div>
  </div>
</div>