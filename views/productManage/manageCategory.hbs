<div class="row g-3 mb-3">
  <div class="col-md-4">
    <div class="border rounded p-3">
      <div class="text-muted small">Tổng danh mục</div>
      <div class="fs-4 fw-bold">2</div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="border rounded p-3">
      <div class="text-muted small">Tổng mặt hàng</div>
      <div class="fs-4 fw-bold">5</div>
    </div>
  </div>
</div>

<!-- Filter option -->
<div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
  <!-- Left buttons -->
  <div class="d-flex gap-2">
    <a href="/good/add">
      <button type="button" class="btn btn-success">
        <i class="bi bi-plus-circle-fill me-1"></i>Thêm danh mục
      </button>
    </a>
  </div>
</div>

<!-- Product table -->
<div class="table-responsive mt-3">
  <table class="table table-striped align-middle">
    <thead>
      <tr>
        <th scope="col">
          <input
            class="form-check-input delete-check"
            type="checkbox"
            value=""
          />
        </th>
        <th scope="col">Tên mặt hàng</th>
        <th scope="col">Số mặt hàng cùng danh mục</th>
      </tr>
    </thead>
    <tbody class="table-group-divider">
      <tr>
        <th scope="row">
          <input
            class="form-check-input delete-check"
            type="checkbox"
            value=""
          />
        </th>
        <td>Cà phê</td>
        <td>3</td>
      </tr>
      <tr>
        <th scope="row">
          <input
            class="form-check-input delete-check"
            type="checkbox"
            value=""
          />
        </th>
        <td>Sâm</td>
        <td>2</td>
      </tr>
    </tbody>
  </table>
</div>

<!-- Table Navigation-->
<div class="d-flex align-items-center" id="tableNav">
  <button type="button" class="btn btn-outline-dark rounded-0 me-1">
    <i class="bi bi-chevron-left"></i>
  </button>
  <button type="button" class="btn btn-outline-dark rounded-0">
    <i class="bi bi-chevron-right"></i>
  </button>
</div>

<!-- New Category Modal -->
<div class="modal fade" id="newCategoryModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Thêm danh mục mới</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">
        <div class="d-flex flex-column">
          <label class="form-label">Tên danh mục</label>
          <input
            type="text"
            class="form-control"
            id="newCategoryName"
            placeholder="Nhập tên danh mục"
          />
        </div>
      </div>
      <div class="modal-footer">
        <button
          type="button"
          class="btn btn-secondary"
          data-bs-dismiss="modal"
        >Hủy</button>
        <button
          type="button"
          class="btn btn-success"
          id="saveCategoryBtn"
        >Lưu</button>
      </div>
    </div>
  </div>
</div>

