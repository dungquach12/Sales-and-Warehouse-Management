<!-- Sale Screen - Bootstrap focused -->
<div class="row g-3">

  <!-- Left panel -->
  <div class="col-12 col-md-8">
    <!-- Search bat -->
    <div class="card mb-3">
      <div class="card-body p-0">
        <div class="input-group">
          <input type="text" class="form-control" placeholder="Search" aria-label="Search" aria-describedby="button-addon2">
          <button class="btn btn-primary" type="button" id="button-addon2">Search</button>
        </div>
      </div>
    </div>

    <!-- Drink selection -->
    <div class="card mb-3">
      <div class="card-body">
        <h6 class="card-title fw-bold"><i class="bi bi-cup-hot me-1"></i>Chọn đồ uống</h6>
        <div class="row row-cols-3 row-cols-sm-4 g-2" id="drinkGrid"></div>
      </div>
    </div>

    <!-- Size -->
    <div class="card mb-3" id="sizePanel" style="display:none;">
      <div class="card-body">
        <h6 class="card-title fw-bold"><i class="bi bi-arrows-expand me-1"></i>Size</h6>
        <div class="btn-group w-100">
          <button class="btn btn-outline-secondary active" data-size="Nhỏ">Nhỏ</button>
          <button class="btn btn-outline-secondary" data-size="Vừa">Vừa</button>
          <button class="btn btn-outline-secondary" data-size="Lớn">Lớn</button>
        </div>
      </div>
    </div>

    <!-- Quantity -->
    <div class="card mb-3">
      <div class="card-body">
        <h6 class="card-title fw-bold"><i class="bi bi-hash me-1"></i>Số lượng</h6>
        <div class="input-group" style="max-width: 160px;">
          <button class="btn btn-outline-secondary" id="qtyMinus">−</button>
          <input type="text" class="form-control text-center fw-bold" id="qtyDisplay" value="1" readonly />
          <button class="btn btn-outline-secondary" id="qtyPlus">+</button>
        </div>
      </div>
    </div>

    <!-- Customer name -->
    <div class="card mb-3">
      <div class="card-body">
        <h6 class="card-title fw-bold">
          <i class="bi bi-person me-1"></i>Tên khách
          <span class="text-muted fw-normal small">(không bắt buộc)</span>
        </h6>
        <input type="text" class="form-control" id="customerName" placeholder="Nhập tên khách hàng..." />
      </div>
    </div>

    <!-- Payment -->
    <div class="card mb-3">
      <div class="card-body">
        <h6 class="card-title fw-bold"><i class="bi bi-wallet2 me-1"></i>Thanh toán</h6>
        <div class="btn-group w-100">
          <button class="btn btn-outline-success active" data-payment="Tiền mặt">
            <i class="bi bi-cash me-1"></i>Tiền mặt
          </button>
          <button class="btn btn-outline-primary" data-payment="Chuyển khoản">
            <i class="bi bi-phone me-1"></i>Chuyển khoản
          </button>
        </div>
      </div>
    </div>

    <button class="btn btn-warning w-100 fw-bold py-3" id="addBtn" disabled>
      <i class="bi bi-plus-circle me-1"></i>Thêm vào đơn
    </button>

  </div>

  <!-- Right panel - order summary -->
  <div class="col-12 col-md-4">
    <div class="card sticky-top">
      <div class="card-body">
        <h6 class="card-title fw-bold"><i class="bi bi-receipt me-1"></i>Đơn hàng</h6>

        <div id="orderList">
          <div class="text-center text-muted py-4">
            <i class="bi bi-cup fs-2 d-block mb-2"></i>
            Chưa có món nào
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-2" id="orderTotal" style="display:none !important;">
          <span class="fw-bold">Tổng cộng</span>
          <span class="fw-bold fs-5 text-warning" id="totalAmount">0đ</span>
        </div>

        <button class="btn btn-dark w-100 fw-bold mt-3 py-2" id="submitBtn" disabled>
          <i class="bi bi-check-circle me-1"></i>Xác nhận đơn
        </button>
      </div>
    </div>
  </div>

</div>

<!-- Toast -->
<div class="position-fixed bottom-0 start-50 translate-middle-x mb-3" style="z-index:999;">
  <div id="toast" class="toast align-items-center text-bg-dark border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body fw-bold" id="toastMsg"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>
  const drinks = [
    { id: 1, name: 'Cà phê đá', emoji: '☕', price: 15000, hasSize: false },
    { id: 2, name: 'Cà phê sữa', emoji: '🥛', price: 18000, hasSize: false },
    { id: 3, name: 'Bạc xỉu', emoji: '🍶', price: 20000, hasSize: false },
    { id: 4, name: 'Rong biển', emoji: '🧊', price: 10000, hasSize: false },
    { id: 5, name: 'Bông cúc', emoji: '🥤', price: 10000, hasSize: true },
    { id: 6, name: 'Nước cam', emoji: '🍊', price: 20000, hasSize: true },
  ];

  let selectedDrink = null;
  let selectedSize = 'Nhỏ';
  let quantity = 1;
  let payment = 'Tiền mặt';
  let orderItems = [];

  // Render drinks
  const grid = document.getElementById('drinkGrid');
  drinks.forEach(d => {
    const col = document.createElement('div');
    col.className = 'col';
    col.innerHTML = `
      <button class="btn btn-outline-secondary w-100 h-100 d-flex flex-column align-items-center py-3 drink-btn" data-id="${d.id}">
        <span style="font-size:1.8rem;">${d.emoji}</span>
        <span class="fw-bold small mt-1">${d.name}</span>
        <span class="text-warning small fw-bold">${d.price.toLocaleString('vi-VN')}đ</span>
      </button>
    `;
    col.querySelector('.drink-btn').addEventListener('click', () => selectDrink(d));
    grid.appendChild(col);
  });

  function selectDrink(drink) {
    selectedDrink = drink;
    document.querySelectorAll('.drink-btn').forEach(b => {
      b.classList.remove('btn-warning', 'text-dark');
      b.classList.add('btn-outline-secondary');
    });
    const selected = document.querySelector(`.drink-btn[data-id="${drink.id}"]`);
    selected.classList.remove('btn-outline-secondary');
    selected.classList.add('btn-warning', 'text-dark');
    document.getElementById('sizePanel').style.display = drink.hasSize ? 'block' : 'none';
    document.getElementById('addBtn').disabled = false;
  }

  // Size
  document.querySelectorAll('[data-size]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-size]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedSize = btn.dataset.size;
    });
  });

  // Quantity
  document.getElementById('qtyMinus').addEventListener('click', () => {
    if (quantity > 1) { quantity--; document.getElementById('qtyDisplay').value = quantity; }
  });
  document.getElementById('qtyPlus').addEventListener('click', () => {
    quantity++;
    document.getElementById('qtyDisplay').value = quantity;
  });

  // Payment
  document.querySelectorAll('[data-payment]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-payment]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      payment = btn.dataset.payment;
    });
  });

  // Add to order
  document.getElementById('addBtn').addEventListener('click', () => {
    if (!selectedDrink) return;
    orderItems.push({
      id: Date.now(),
      drink: selectedDrink,
      size: selectedDrink.hasSize ? selectedSize : null,
      quantity,
      price: selectedDrink.price * quantity,
      customer: document.getElementById('customerName').value.trim()
    });
    renderOrder();
    showToast(`✓ Đã thêm ${selectedDrink.name}`);
    quantity = 1;
    document.getElementById('qtyDisplay').value = 1;
  });

  function renderOrder() {
    const list = document.getElementById('orderList');
    const total = document.getElementById('orderTotal');

    if (orderItems.length === 0) {
      list.innerHTML = `<div class="text-center text-muted py-4"><i class="bi bi-cup fs-2 d-block mb-2"></i>Chưa có món nào</div>`;
      total.style.display = 'none';
      document.getElementById('submitBtn').disabled = true;
      return;
    }

    list.innerHTML = orderItems.map(item => `
      <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
        <div>
          <div class="fw-bold small">${item.drink.emoji} ${item.drink.name}</div>
          <div class="text-muted" style="font-size:0.75rem;">
            ${item.size ? item.size + ' · ' : ''}x${item.quantity}
            ${item.customer ? '· ' + item.customer : ''}
          </div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold text-warning small">${item.price.toLocaleString('vi-VN')}đ</span>
          <button class="btn btn-sm btn-link text-danger p-0" onclick="removeItem(${item.id})">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      </div>
    `).join('');

    const grandTotal = orderItems.reduce((sum, i) => sum + i.price, 0);
    document.getElementById('totalAmount').textContent = grandTotal.toLocaleString('vi-VN') + 'đ';
    total.style.display = 'flex';
    document.getElementById('submitBtn').disabled = false;
  }

  function removeItem(id) {
    orderItems = orderItems.filter(i => i.id !== id);
    renderOrder();
  }

  document.getElementById('submitBtn').addEventListener('click', () => {
    if (orderItems.length === 0) return;
    const total = orderItems.reduce((sum, i) => sum + i.price, 0);
    showToast(`✓ Đơn ${total.toLocaleString('vi-VN')}đ đã lưu!`);
    orderItems = [];
    renderOrder();
    selectedDrink = null;
    document.querySelectorAll('.drink-btn').forEach(b => {
      b.classList.remove('btn-warning', 'text-dark');
      b.classList.add('btn-outline-secondary');
    });
    document.getElementById('addBtn').disabled = true;
    document.getElementById('customerName').value = '';
  });

  function showToast(msg) {
    document.getElementById('toastMsg').textContent = msg;
    const toast = new bootstrap.Toast(document.getElementById('toast'), { delay: 2000 });
    toast.show();
  }
</script>
